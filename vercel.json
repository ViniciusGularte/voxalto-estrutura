{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/t/christye",
      "destination": "/"
    },
    {
      "source": "/t/christye/:path*",
      "destination": "/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Site",
          "value": "christye-biagio"
        }
      ]
    }
  ]
}
